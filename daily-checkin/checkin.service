User=pays0n
WorkingDirectory=/home/pays0n/Documents/Projects/habit-tracking/daily-checkin
ExecStart=/home/pays0n/Documents/Projects/habit-tracking/daily-checkin/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8900
